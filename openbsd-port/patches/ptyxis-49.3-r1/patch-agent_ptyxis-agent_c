$OpenBSD$

Add pledge(2) to ptyxis-agent to restrict system call access after startup.

The agent only needs to: spawn shells (proc+exec), manage PTYs (tty+rpath+wpath),
communicate over D-Bus socketpair (stdio+unix+sendfd+recvfd), and look up user
info for login shells (getpw). Network access is intentionally excluded.

If pledge fails the agent exits with a fatal error rather than silently continuing
with full privileges, following OpenBSD security best practices.

--- agent/ptyxis-agent.c.orig
+++ agent/ptyxis-agent.c
@@ -26,6 +26,10 @@
 #include <string.h>
 #include <unistd.h>

+#ifdef __OpenBSD__
+# include <errno.h>
+#endif
+
 #include <glib.h>
 #include <glib-unix.h>
 #include <glib/gstdio.h>
@@ -205,6 +209,21 @@ main (int   argc,
   g_set_prgname ("ptyxis-agent");
   g_set_application_name ("ptyxis-agent");

+#ifdef __OpenBSD__
+  /*
+   * Restrict system calls early. The agent needs:
+   *   stdio      - basic I/O, wait4, kqueue, pipe
+   *   rpath      - read shell binaries, /etc/passwd, config files
+   *   wpath      - write access paired with tty for PTY setup
+   *   tty        - posix_openpt, grantpt, unlockpt, ioctl on PTYs
+   *   proc       - fork, setpgid, kill for child process management
+   *   exec       - execve to launch user shells
+   *   unix       - D-Bus socketpair communication
+   *   sendfd     - pass PTY master fd to ptyxis over D-Bus
+   *   recvfd     - receive fds from ptyxis
+   *   getpw      - getpwuid/getpwnam for login shell resolution
+   */
+  if (pledge ("stdio rpath wpath tty proc exec unix sendfd recvfd getpw", NULL) == -1)
+    {
+      g_printerr ("ptyxis-agent: pledge: %s\n", g_strerror (errno));
+      return EXIT_FAILURE;
+    }
+#endif
+
   context = g_option_context_new ("- terminal container agent");
   g_option_context_add_main_entries (context, entries, GETTEXT_PACKAGE);
   if (!g_option_context_parse (context, &argc, &argv, &error) ||
