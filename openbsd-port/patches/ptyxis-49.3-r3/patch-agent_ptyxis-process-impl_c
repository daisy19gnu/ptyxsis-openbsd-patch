+#elif defined(__OpenBSD__)
+  {
+    int mib[4] = { CTL_KERN, KERN_PROC_ARGS, (int)pid, KERN_PROC_ARGV };
+    size_t len = 0;
+
+    if (sysctl (mib, 4, NULL, &len, NULL, 0) == 0 && len > 0)
+      {
+        g_autofree char *buf = g_malloc (len);
+
+        if (sysctl (mib, 4, buf, &len, NULL, 0) == 0)
+          {
+            char **argv = (char **)buf;
+            GString *str = g_string_new (NULL);
+
+            for (int i = 0; argv[i] != NULL; i++)
+              {
+                if (i > 0)
+                  g_string_append_c (str, ' ');
+                g_string_append (str, argv[i]);
+              }
+
+            if (str->len > 1024)
+              g_string_truncate (str, 1024);
+
+            cmdline = g_string_free (str, FALSE);
+          }
+      }
+  }
 #endif

   return g_steal_pointer (&cmdline);
