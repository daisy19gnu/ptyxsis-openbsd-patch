+      if (kp.p_uid == 0)
+        return "superuser";
+
+      leader_kind = g_hash_table_lookup (exec_to_kind, kp.p_comm);
+    }
+
+  if (leader_kind == NULL)
+    leader_kind = "unknown";
+
+  return leader_kind;
