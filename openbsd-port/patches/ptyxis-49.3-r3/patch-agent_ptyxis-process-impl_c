 get_leader_kind (GPid pid)
 {
+#ifdef __OpenBSD__
+  struct kinfo_proc kp;
+  int mib[6] = { CTL_KERN, KERN_PROC, KERN_PROC_PID, (int)pid,
+                  sizeof (struct kinfo_proc), 1 };
+  size_t len = sizeof (kp);
+  const char *leader_kind = NULL;
+
+  if (sysctl (mib, 6, &kp, &len, NULL, 0) == 0)
