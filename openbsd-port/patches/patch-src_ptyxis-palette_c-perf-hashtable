+static void
+palette_items_changed_cb (GListModel *model,
+                          guint       position,
+                          guint       removed,
+                          guint       added,
+                          gpointer    user_data)
+{
+  if (removed > 0)
+    {
+      /* Items were removed: cannot know their IDs after the fact,
+       * so rebuild the full index from the current model state. */
+      guint n_items = g_list_model_get_n_items (model);
+
+      g_hash_table_remove_all (palette_index);
+
+      for (guint i = 0; i < n_items; i++)
+        {
+          g_autoptr(PtyxisPalette) p = g_list_model_get_item (model, i);
+          g_hash_table_insert (palette_index, (gpointer)ptyxis_palette_get_id (p), p);
+        }
+    }
+  else
+    {
+      /* Pure addition: index only the newly inserted items. */
+      for (guint i = position; i < position + added; i++)
+        {
+          g_autoptr(PtyxisPalette) p = g_list_model_get_item (model, i);
+          g_hash_table_insert (palette_index, (gpointer)ptyxis_palette_get_id (p), p);
+        }
+    }
+}
